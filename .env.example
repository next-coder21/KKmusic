# ────────────────────────────────────────────────────────────────
# KK-lisn — frontend environment variables
# Copy to .env.local for local dev; set the same keys in your
# Vercel project's Environment Variables panel for deploys.
# Vite only exposes vars prefixed with VITE_ to the browser.
# ────────────────────────────────────────────────────────────────

# Backend API base URL (KKaudioBk service)
VITE_API_BASE_URL=http://localhost:5000

# Marketing site URL (muveswb)
VITE_WEBSITE_URL=https://muves.in
